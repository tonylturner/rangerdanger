# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace
go.work
go.work.sum
backend/.gomodcache/
backend/.gocache/

# env file
.env

# setup.sh host-state markers (e.g. amd64 binfmt registration on arm64 Linux)
.setup-binfmt-amd64

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
Icon

# Node / Next.js
node_modules/
.next/
npm-debug.log*
pnpm-debug.log*
*.log

# Build artifacts
frontend/.next/
frontend/node_modules/
# Auto-generated by `next dev`/`next build`; regenerated on demand, and
# its boilerplate comment churns across Next.js versions. Next's own
# create-next-app gitignores it by default.
frontend/next-env.d.ts
*.tsbuildinfo
backend/server
dnp3go/dnp3cmd
dnp3go/dnp3poll

# Python — bytecode and tooling caches. The Python services (opendss-sim)
# run in containers; these only show up when Python tooling runs on the
# host (a local venv, a stray import, an editor). Never belong in the repo.
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.venv/
venv/

# Runtime data — all generated at startup / by containers
# Nothing in data/ needs to be in the repo
data/
backend/data/
fuxa_appdata/
fuxa_db/
fuxa_logs/

# Personal IDE/agent settings
.claude/
.cursor/
.idea/
.vscode/

# Stray/empty
deploy/

# SSD staging output. stage-ssd.sh and stage-ssd-delta.sh write image
# tarballs (~6 GB each) plus rangerdanger.tgz; if the operator passes
# a relative output path like ./out instead of /Volumes/SOMETHING,
# the bundle lands inside the repo and would otherwise appear as
# untracked. External mounts (/Volumes/*) are already outside the
# working tree and not git's concern.
out/
images-amd64.tar
images-arm64.tar
delta-amd64.tar
delta-arm64.tar
rangerdanger.tgz
DELTA-README.md

# Large binary tools (not in git, fetched separately)
tools/pcap-analyzer/*.deb

# Local-only AI agent context (Claude Code)
CLAUDE.md

# Working backlog - kept local, not part of the public docs. ROADMAP.md
# is the public forward-looking doc; CHANGELOG.md is the public history.
# docs/tasks.md is private operator notes that aren't useful to external
# readers.
docs/tasks.md

# Internal maintainer tooling docs. The leading-underscore convention
# assumes a Jekyll/Hugo-style docs site; a plain GitHub repo publishes
# the directory regardless, so untrack and ignore it. Keep files
# locally for maintainer use (e.g. docs/_internal/pdf-update-prompt.md).
docs/_internal/

# Playwright MCP local QA artifacts — screenshots and page snapshots from
# local UI verification. Useful locally, not part of the repo.
.playwright-mcp/
supervisory-control-2x2.png
